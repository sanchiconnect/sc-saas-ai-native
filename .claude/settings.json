{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run lint*)",
      "Bash(npm run test*)",
      "Bash(npm test*)",
      "Bash(npm run build*)",
      "Bash(npx tsc*)",
      "Bash(npx eslint*)",
      "Bash(ng test*)",
      "Bash(ng lint*)",
      "Bash(jest*)",
      "Bash(php -l *)",
      "Bash(composer validate*)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(git commit*)",
      "Bash(*deploy*)",
      "Bash(npm publish*)",
      "Bash(serverless*)",
      "Bash(pm2*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa*)",
      "Read(sc-saas-admin/config/db_settings.php)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)"
    ],
    "additionalDirectories": [
      "/Users/mac/Desktop/Work/SanchiSaaS/sanchiconnect-saas-tenants",
      "/Users/mac/Desktop/Work/SanchiSaaS/sc-saas-backend",
      "/Users/mac/Desktop/Work/SanchiSaaS/sc-saas-frontend",
      "/Users/mac/Desktop/Work/SanchiSaaS/sc-saas-admin"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/guard-sensitive-files.sh"
          }
        ]
      }
    ]
  }
}
